       </property>
       <property name="styleSheet">
        <string notr="true">QPushButton {
    /* 强行固定宽高，不允许拉伸 */
    min-width: 69px;
    max-width: 69px;
    min-height: 24px;
    max-height: 24px;

    /* 你的主题青绿色 */
    background-color: #00c4a7;
    color: #ffffff;
    
    /* 严格直角与扁平化 */
    border-radius: 0px;
    border: none;
    
    /* 小尺寸下，字号12px~13px最精致，14px可能会显得太满 */
    font-size: 12px; 
    font-weight: bold;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
    
    /* 清除内边距，靠强制宽高来撑开 */
    padding: 0px; 
}

/* 鼠标悬浮状态 */
QPushButton:hover {
    background-color: #00d9b9;
}

/* 鼠标按下状态 */
QPushButton:pressed {
    background-color: #00a88f;
    /* 小尺寸下的点击反馈，文字向下向右微移 1 像素 */
    padding-left: 1px;
    padding-top: 1px;
}</string>
