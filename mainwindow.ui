       <property name="styleSheet">
        <string notr="true">QPushButton {
    /* 基础背景色：来自 image_2d978b.png 的青绿色 */
    background-color: #00c4a7;
    /* 文字颜色：纯白 */
    color: #ffffff;
    /* 严格直角，无圆角 */
    border-radius: 0px;
    /* 去掉默认边框，确保纯扁平 */
    border: none;
    /* 内边距 */
    padding: 8px 20px;
    font-size: 14px;
    font-weight: bold;
    font-family: &quot;Microsoft YaHei&quot;, sans-serif;
}

/* 鼠标悬浮状态：颜色稍微提亮一点 */
QPushButton:hover {
    background-color: #00d9b9;
}

/* 鼠标按下状态：颜色加深，体现点击感 */
QPushButton:pressed {
    background-color: #00a88f;
    /* 扁平风格下，按下时文字微调1px能带来很好的物理反馈，不需要可删掉 */
    padding-left: 21px;
    padding-top: 9px;
}</string>
       </property>
