       <property name="styleSheet">
        <string notr="true">/* 1. 默认状态（未选中时）的文字颜色（例如黑色或默认深色） */
QCheckBox {
    color: #333333; 
    font-size: 12px;
}

/* 2. 选中状态（checked）下的文字颜色变红 */
QCheckBox:checked {
    color: #ff0000; /* 纯红，也可以用 #e74c3c 等更柔和的红 */
}</string>
